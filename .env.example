# ============================================================================
# Shirimim — environment variables
# Copy to ".env.local" for local dev, and paste the same values into the
# Vercel project's Environment Variables for production.
# ============================================================================

# Supabase project URL.
# Supabase dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Public anon key. Safe to expose. Kept for completeness / future client use.
# Supabase dashboard -> Project Settings -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key. SECRET — server-side only (search API, daily roll, cron).
# Never expose this to the browser. Do NOT prefix it with NEXT_PUBLIC_.
# Supabase dashboard -> Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Shared secret guarding the daily cron route (/api/cron/roll).
# Any random string; set the same value in Vercel.
CRON_SECRET=change-me-to-a-long-random-string
